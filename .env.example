# Do not put a real password in this file.
DATABASE_URL=postgresql://USER:PASSWORD@DIRECT_HOST/DATABASE?sslmode=require
# Copy the exact pooled connection string from Neon's Connect dialog.
DATABASE_POOL_URL=postgresql://USER:PASSWORD@POOLER_HOST/DATABASE?sslmode=require
# Migrations, backup and restore use the direct connection.
DATABASE_DIRECT_URL=postgresql://USER:PASSWORD@DIRECT_HOST/DATABASE?sslmode=require
# Optional on Render because RENDER_EXTERNAL_URL is supplied automatically.
# Set this when a custom domain becomes the primary website address.
APP_ORIGIN=https://orders.example.com
NODE_ENV=production
BACKUP_ENCRYPTION_KEY=replace-with-a-long-random-secret
PORT=8765
