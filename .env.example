# Do not put a real password in this file.
DATABASE_URL=postgresql://USER:PASSWORD@DIRECT_HOST/DATABASE?sslmode=require
# Copy the exact pooled connection string from Neon's Connect dialog.
DATABASE_POOL_URL=postgresql://USER:PASSWORD@POOLER_HOST/DATABASE?sslmode=require
# Migrations, backup and restore use the direct connection.
DATABASE_DIRECT_URL=postgresql://USER:PASSWORD@DIRECT_HOST/DATABASE?sslmode=require
# Production uses one main domain with two isolated subdomains.
TEACHER_HOST=orders.example.com
AGENT_HOST=agent.example.com
TEACHER_ORIGIN=https://orders.example.com
AGENT_ORIGIN=https://agent.example.com
# Optional comma-separated preview origins used during acceptance testing.
APP_ORIGINS=https://preview.example.com
NODE_ENV=production
BACKUP_ENCRYPTION_KEY=replace-with-a-long-random-secret
BACKUP_DIR=backups
# COS upload is performed by deploy/backup-to-cos.ps1 after an encrypted backup succeeds.
COS_BUCKET=tutor-backups-APPID
COS_REGION=ap-chengdu
PORT=8765
